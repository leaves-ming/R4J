{
  "title": "RAG Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "panels": [
    {
      "title": "Ingestion Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_ingestion_requests_total[5m]))"
        }
      ]
    },
    {
      "title": "Ingestion Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_ingestion_failed_total[5m]))"
        }
      ]
    },
    {
      "title": "Query Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_query_requests_total[5m]))"
        }
      ]
    },
    {
      "title": "Query Fallbacks",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_query_fallback_total[5m])) by (failedPath)"
        }
      ]
    },
    {
      "title": "Query Responses",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_query_response_total[5m])) by (partialFallback, rerankApplied)"
        }
      ]
    },
    {
      "title": "Evaluation Runs",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_evaluation_run_total_total[5m]))"
        }
      ]
    },
    {
      "title": "Evaluation Cases",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_evaluation_case_total_total[5m]))"
        }
      ]
    }
  ]
}
