{
  "title": "RAG Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "panels": [
    {
      "title": "Ingestion Total",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_ingestion_total[5m]))"
        }
      ]
    },
    {
      "title": "Ingestion Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_ingestion_failure_total[5m]))"
        }
      ]
    },
    {
      "title": "Ingestion Compensation",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_ingestion_compensation_total[5m]))"
        }
      ]
    },
    {
      "title": "Query Total",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_query_total[5m]))"
        }
      ]
    },
    {
      "title": "Query Fallbacks",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_retrieval_fallback_total[5m])) by (failedPath)"
        }
      ]
    },
    {
      "title": "Query Responses",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_query_response_total[5m])) by (partialFallback, rerankApplied)"
        }
      ]
    },
    {
      "title": "Dense Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_dense_latency_ms_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "Sparse Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_sparse_latency_ms_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "Rerank Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_rerank_latency_ms_seconds_bucket[5m])) by (le, provider))"
        }
      ]
    },
    {
      "title": "Evaluation Runs",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_evaluation_run_total[5m]))"
        }
      ]
    },
    {
      "title": "Evaluation Cases",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_evaluation_case_total[5m]))"
        }
      ]
    }
  ]
}
